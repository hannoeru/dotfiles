{{- if eq .chezmoi.os "darwin" }}
alias dl="cd ~/Downloads"
alias p="nr preview"
alias forks="cd ~/Projects/forks"
alias brewup='brew update; brew upgrade; brew cleanup'

if which eza >/dev/null 2>&1; then
  alias l="eza -g --icons"
  alias ls="l"
  alias ll="l -l"
  alias lla="ll -a"
fi
{{- end }}
